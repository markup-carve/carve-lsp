{
  "name": "@markup-carve/carve-lsp",
  "version": "0.1.0",
  "type": "module",
  "description": "Language server for Carve markup documents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markup-carve/carve-lsp.git"
  },
  "homepage": "https://github.com/markup-carve/carve-lsp#readme",
  "bugs": "https://github.com/markup-carve/carve-lsp/issues",
  "keywords": [
    "carve",
    "lsp",
    "language-server",
    "markup"
  ],
  "bin": {
    "carve-lsp": "./dist/server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/analyze.js",
      "types": "./dist/analyze.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "node --test dist/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@markup-carve/carve": "github:markup-carve/carve-js#e28acbf",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
